# ============================================
# PharmaManager — Docker Environment Variables
# Copy this file to .env.docker and fill values
# ============================================

# Django
SECRET_KEY=change-me-to-a-random-secret-key
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DB_NAME=pharma_manager
DB_USER=pharma_user
DB_PASSWORD=pharma_password

# CORS (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:80

# Frontend
VITE_API_BASE_URL=/api/v1
